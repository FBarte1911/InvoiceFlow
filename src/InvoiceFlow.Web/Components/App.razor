                    },
                    fontFamily: {
                        "mono-sm": ["JetBrains Mono"],
                        "mono-lg": ["JetBrains Mono"],
                        "h2": ["Inter"],
                        "h3": ["Inter"],
                        "h1-mobile": ["Inter"],
                        "body-lg": ["Inter"],
                        "h1": ["Inter"],
                        "body-md": ["Inter"],
                        "mono-md": ["JetBrains Mono"],
                        "body-sm": ["Inter"]
