                        "surface-tint": "#565e74",
                        "secondary-fixed-dim": "#2fd9f4",
                        "on-secondary-fixed": "#001f25",
                        "surface-bright": "#f8f9ff",
                        "background": "#f8f9ff",
                        "error": "#ba1a1a",
                        "on-error-container": "#93000a",
                        "surface-container-highest": "#d3e4fe",
                        "outline": "#76777d",
                        "secondary-fixed": "#a2eeff",
