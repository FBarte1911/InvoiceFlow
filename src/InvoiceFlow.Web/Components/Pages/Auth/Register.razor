@page "/register"
@layout AuthLayout

<PageTitle>Crear cuenta — InvoiceFlow</PageTitle>

<!-- Left Side: Brand Visual & Messaging -->
<section class="hidden lg:flex flex-col justify-between w-[45%] login-bg-pattern p-stack_lg relative overflow-hidden">
    <div class="absolute top-[-10%] right-[-10%] w-64 h-64 bg-secondary-container opacity-10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-[-5%] left-[-5%] w-80 h-80 bg-primary-fixed-dim opacity-5 rounded-full blur-3xl"></div>

    <div class="relative z-10">
        <div class="flex items-center gap-3">
            <div class="bg-secondary-container p-2 rounded-lg">
                <span class="material-symbols-outlined text-on-secondary-fixed text-h3">description</span>
            </div>
            <span class="font-h3 text-h3 font-bold text-white tracking-tight">InvoiceFlow</span>
        </div>
    </div>

    <div class="relative z-10 max-w-md">
        <h1 class="font-h1 text-h1 text-white mb-stack_md leading-tight">
            Cobrá más rápido. Sin esfuerzo.
        </h1>
        <p class="font-body-lg text-body-lg text-primary-fixed-dim">
            La plataforma de facturación inteligente diseñada para freelancers en LATAM que valoran su tiempo y profesionalismo.
        </p>
    </div>

    <div class="relative z-10">
        <div class="flex gap-4 items-center">
            <div class="flex -space-x-2">
                <div class="w-10 h-10 rounded-full border-2 border-[#0F172A] bg-secondary-container flex items-center justify-center text-on-secondary-fixed font-bold text-sm">MG</div>
                <div class="w-10 h-10 rounded-full border-2 border-[#0F172A] bg-primary-fixed flex items-center justify-center text-on-surface font-bold text-sm">CR</div>
                <div class="w-10 h-10 rounded-full border-2 border-[#0F172A] bg-surface-variant flex items-center justify-center text-on-surface font-bold text-sm">AS</div>
            </div>
            <p class="font-body-sm text-body-sm text-primary-fixed-dim">
                Únete a más de <span class="font-bold text-white">5,000+</span> profesionales hoy.
            </p>
        </div>
    </div>
</section>

<!-- Right Side: Registration Form -->
<main class="w-full lg:w-[55%] bg-surface flex items-center justify-center p-gutter md:p-stack_lg overflow-y-auto">
    <div class="w-full max-w-[480px]">
        <div class="lg:hidden flex items-center gap-2 mb-stack_lg justify-center">
            <span class="material-symbols-outlined text-secondary text-h3">description</span>
            <span class="font-h3 text-h3 font-bold text-on-surface">InvoiceFlow</span>
        </div>

        <div class="bg-surface-container-lowest p-stack_md md:p-stack_lg rounded-xl shadow-sm border border-outline-variant">
            <header class="mb-stack_lg text-center lg:text-left">
                <h2 class="font-h2 text-h2 text-on-surface mb-2">Crear cuenta</h2>
                <p class="font-body-sm text-body-sm text-on-surface-variant">
                    Comienza tu prueba gratuita de 14 días. No requiere tarjeta.
                </p>
            </header>

            <div class="space-y-4">
                <a href="/Account/Register/Google" class="w-full flex items-center justify-center gap-3 py-3 px-4 border border-outline-variant rounded-lg font-body-md text-on-surface hover:bg-surface-container-low transition-colors duration-200">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    <span>Continuar con Google</span>
                </a>

                <div class="flex items-center gap-4 my-stack_lg">
                    <div class="h-[1px] bg-outline-variant flex-grow"></div>
                    <span class="font-mono-sm text-mono-sm text-outline uppercase tracking-wider">o registra tu email</span>
                    <div class="h-[1px] bg-outline-variant flex-grow"></div>
                </div>

                <a href="/Account/Register" class="w-full py-4 bg-primary text-white font-bold rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all duration-200 flex items-center justify-center">
                    Empezar ahora
                </a>
            </div>

            <footer class="mt-stack_lg pt-stack_md border-t border-outline-variant text-center">
                <p class="font-body-sm text-body-sm text-on-surface-variant">
                    ¿Ya tienes una cuenta?
                    <a class="text-secondary font-bold hover:underline ml-1" href="/Account/Login">Inicia sesión</a>
                </p>
            </footer>
        </div>

        <div class="mt-stack_lg flex justify-center gap-stack_lg opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
            <div class="flex items-center gap-1 font-mono-sm text-mono-sm">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">lock</span>
                <span>Encriptación SSL</span>
            </div>
            <div class="flex items-center gap-1 font-mono-sm text-mono-sm">
                <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 1;">verified_user</span>
                <span>Soporte 24/7</span>
            </div>
        </div>
    </div>
</main>

