@page "/templates"
@using InvoiceFlow.Application.Subscriptions.Queries.GetCurrentSubscription
@using MediatR
@inject IMediator Mediator
@rendermode InteractiveServer
@attribute [Authorize]

<PageTitle>Plantillas — InvoiceFlow</PageTitle>

<div class="p-6">

    @* Header *@
    <div class="flex justify-between items-end mb-7">
        <div>
            <h1 class="text-3xl font-bold text-on-surface">Plantillas de Factura</h1>
            <p class="text-base text-on-surface-variant mt-1">Elegí el diseño que mejor represente tu trabajo.</p>
        </div>
        @if (_subscription?.CustomLogoEnabled == true)
        {
            <span class="flex items-center gap-2 text-sm font-semibold bg-green-100 text-green-800 border border-green-200 px-3 py-1.5 rounded-full">
                <span class="material-symbols-outlined" style="font-size:16px;font-variation-settings:'FILL' 1;">verified</span>
                Logo personalizado activo
            </span>
        }
    </div>

    @if (_subscription is null)
    {
        <div class="flex items-center justify-center py-20">
            <div class="flex items-center gap-3 text-on-surface-variant">
                <span class="material-symbols-outlined" style="font-size:24px;">progress_activity</span>
                <span class="text-sm">Cargando...</span>
            </div>
        </div>
    }
    else
    {
        @* Template Grid *@
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-8">
            @foreach (var tmpl in _templates)
            {
                var isLocked = tmpl.IsPro && !_subscription.CustomLogoEnabled;
                <div class="group cursor-pointer">
                    <div class="relative bg-surface-container-lowest border @(isLocked ? "border-outline-variant" : "border-secondary/30") rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-all" style="aspect-ratio:3/4;">
                        @* Preview area *@
                        <div class="w-full h-full flex flex-col items-center justify-center bg-gradient-to-br from-surface-container-low to-surface-container gap-3 p-8">
                            <span class="text-5xl">@tmpl.Emoji</span>
                            <div class="w-full space-y-2 mt-2">
                                <div class="h-2 bg-outline-variant/40 rounded-full w-3/4 mx-auto"></div>
                                <div class="h-1.5 bg-outline-variant/30 rounded-full w-1/2 mx-auto"></div>
                                <div class="mt-4 space-y-1">
                                    <div class="h-1.5 bg-outline-variant/25 rounded-full"></div>
                                    <div class="h-1.5 bg-outline-variant/25 rounded-full w-5/6"></div>
                                    <div class="h-1.5 bg-outline-variant/25 rounded-full w-4/6"></div>
                                </div>
                                <div class="mt-4 pt-3 border-t border-outline-variant/30 flex justify-between">
                                    <div class="h-2 bg-outline-variant/30 rounded-full w-1/4"></div>
                                    <div class="h-2 bg-secondary/40 rounded-full w-1/4"></div>
                                </div>
                            </div>
                        </div>
                        @* Hover overlay *@
                        <div class="absolute inset-0 bg-on-surface/30 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center backdrop-blur-[2px]">
                            @if (isLocked)
                            {
                                <div class="flex flex-col items-center gap-2">
                                    <span class="material-symbols-outlined text-white" style="font-size:28px;">lock</span>
                                    <a href="/pricing" class="bg-secondary text-on-secondary px-5 py-2 rounded-lg text-sm font-semibold shadow-lg">Ver Plan Pro</a>
                                </div>
                            }
                            else
                            {
                                <a href="/invoices/new" class="bg-secondary text-on-secondary px-5 py-2 rounded-lg text-sm font-semibold shadow-lg">Usar plantilla</a>
                            }
                        </div>
                        @* Badge *@
                        @if (isLocked)
                        {
                            <div class="absolute top-3 right-3 bg-secondary text-on-secondary text-xs font-bold px-2 py-0.5 rounded-full shadow">Pro</div>
                        }
                        else if (!tmpl.IsPro)
                        {
                            <div class="absolute top-3 right-3 bg-green-100 text-green-800 text-xs font-bold px-2 py-0.5 rounded-full border border-green-200">Gratis</div>
                        }
                        else
                        {
                            <div class="absolute top-3 right-3 bg-secondary-container text-on-secondary-container text-xs font-bold px-2 py-0.5 rounded-full">Pro ✓</div>
                        }
                    </div>
                    <div class="mt-3 flex items-center justify-between px-1">
                        <h4 class="text-sm font-semibold text-on-surface">@tmpl.Name</h4>
                        @if (isLocked)
                        {
                            <span class="text-xs text-on-surface-variant">Solo Pro</span>
                        }
                    </div>
                    <p class="text-xs text-on-surface-variant mt-0.5 px-1">@tmpl.Description</p>
                </div>
            }
        </div>

        @* Pro Gate *@
        @if (!_subscription.CustomLogoEnabled)
        {
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-10 shadow-sm flex flex-col items-center text-center gap-4 max-w-2xl mx-auto">
                <div class="w-16 h-16 bg-secondary-container rounded-full flex items-center justify-center">
                    <span class="material-symbols-outlined text-on-secondary-container" style="font-size:28px;">style</span>
                </div>
                <div>
                    <h2 class="text-xl font-bold text-on-surface mb-2">Plantillas premium en Plan Pro</h2>
                    <p class="text-sm text-on-surface-variant">Con el Plan Pro podés agregar tu logo, personalizar colores y usar plantillas diseñadas profesionalmente que impresionan a tus clientes.</p>
                </div>
                <a href="/pricing" class="flex items-center gap-2 bg-secondary text-on-secondary px-6 py-3 rounded-lg text-sm font-bold hover:brightness-110 transition-all shadow-sm">
                    <span class="material-symbols-outlined" style="font-size:16px;">star</span>
                    Ver Plan Pro
                </a>
            </div>
        }
    }
</div>

@code {
    private Application.Subscriptions.Dtos.SubscriptionDto? _subscription;

    private static readonly List<TemplateItem> _templates =
    [
        new("Estándar", "La plantilla clásica de InvoiceFlow. Limpia, profesional y clara.", "📄", false),
        new("Freelancer", "Diseñada para el trabajo independiente, con sección de términos.", "💼", false),
        new("Minimalista", "Diseño ultra-limpio, ideal para creativos y diseñadores.", "✨", true),
        new("Moderno", "Colores vibrantes y tipografía moderna. Ideal para agencias.", "🎨", true),
        new("Corporativo", "Estructura formal con espacios para firma y RUT. Ideal para empresas.", "🏢", true),
        new("Internacional", "Optimizada para clientes en el exterior, multi-moneda visible.", "🌎", true),
    ];

    protected override async Task OnInitializedAsync() =>
        _subscription = await Mediator.Send(new GetCurrentSubscriptionQuery());

    private sealed record TemplateItem(string Name, string Description, string Emoji, bool IsPro);
}
