@using InvoiceFlow.Application.Subscriptions.Commands.UpdateTaxDefaults
@using InvoiceFlow.Application.Subscriptions.Dtos
@using MediatR
@inject IMediator Mediator

<section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm space-y-6">
    <div>
        <h2 class="text-lg font-semibold text-on-surface mb-1">Impuesto por defecto</h2>
        <p class="text-sm text-on-surface-variant mb-5">Se aplicará a todas las facturas nuevas. Podés sobrescribirlo por factura.</p>

        <div class="space-y-4">
            <div>
                <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1.5">Etiqueta del impuesto</label>
                <input @bind="_taxLabel" type="text" maxlength="20" placeholder="IVA"
                    class="w-full px-3 py-2 rounded-lg border border-outline-variant bg-surface text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-secondary/40" />
                <p class="text-xs text-on-surface-variant mt-1">Ej: IVA, IGV, ISR, GST</p>
            </div>
            <div>
                <label class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1.5">Tasa (%)</label>
                <input @bind="_taxRate" type="number" min="0" max="100" step="0.01" placeholder="0"
                    class="w-full px-3 py-2 rounded-lg border border-outline-variant bg-surface text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-secondary/40" />
            </div>
        </div>

        @if (_taxError is not null)
        {
            <p class="mt-3 text-xs text-error">@_taxError</p>
        }
        @if (_taxSaved)
        {
            <p class="mt-3 text-xs text-secondary font-semibold">Guardado correctamente.</p>
        }

        <div class="flex justify-end mt-5">
            <button @onclick="SaveTaxDefaultsAsync" disabled="@_isSavingTax"
                class="px-5 py-2 bg-secondary text-on-secondary rounded-lg text-sm font-semibold hover:opacity-90 transition-all disabled:opacity-50">
                @(_isSavingTax ? "Guardando..." : "Guardar")
            </button>
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public SubscriptionDto Subscription { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnSubscriptionChanged { get; set; }

    private decimal _taxRate;
    private string _taxLabel = "IVA";
    private bool _isSavingTax;
    private string? _taxError;
    private bool _taxSaved;

    protected override void OnParametersSet()
    {
        _taxRate = Subscription.DefaultTaxRate;
        _taxLabel = Subscription.TaxLabel;
    }

    private async Task SaveTaxDefaultsAsync()
    {
        _taxError = null; _taxSaved = false; _isSavingTax = true;
        try
        {
            await Mediator.Send(new UpdateTaxDefaultsCommand(_taxRate, _taxLabel));
            _taxSaved = true;
            await OnSubscriptionChanged.InvokeAsync();
        }
        catch (Exception ex) { _taxError = ex.Message; }
        finally { _isSavingTax = false; }
    }
}
