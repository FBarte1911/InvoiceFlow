@using InvoiceFlow.Application.Subscriptions.Commands.UpdateMercadoPagoToken
@using InvoiceFlow.Application.Subscriptions.Dtos
@using MediatR
@inject IMediator Mediator

<section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm space-y-6">
    <div>
        <h2 class="text-lg font-semibold text-on-surface mb-1">Pagos online</h2>
        <p class="text-sm text-on-surface-variant mb-5">Conectá una pasarela de pago para generar links de cobro automáticamente al enviar facturas.</p>

        <div class="p-4 border border-outline-variant rounded-xl mb-4">
            <div class="flex items-center gap-3 mb-1">
                <span class="material-symbols-outlined text-secondary" style="font-size:20px;">payments</span>
                <span class="text-sm font-semibold text-on-surface">Stripe</span>
                <span class="text-xs font-semibold text-secondary bg-secondary-container/20 px-2 py-0.5 rounded-full">Configurado globalmente</span>
            </div>
            <p class="text-xs text-on-surface-variant">La clave de Stripe se configura en las variables de entorno del servidor.</p>
        </div>

        <div class="p-4 border border-outline-variant rounded-xl">
            <div class="flex items-center gap-3 mb-3">
                <span class="material-symbols-outlined @(Subscription.MercadoPagoEnabled ? "text-secondary" : "text-outline-variant")" style="font-size:20px;">account_balance_wallet</span>
                <span class="text-sm font-semibold text-on-surface">MercadoPago</span>
                @if (!Subscription.MercadoPagoEnabled)
                {
                    <a href="/pricing" class="text-xs font-semibold text-on-surface-variant hover:text-secondary transition-colors">Solo en plan Team →</a>
                }
            </div>

            @if (Subscription.MercadoPagoEnabled)
            {
                @if (Subscription.HasMercadoPagoToken)
                {
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2 text-xs text-secondary font-semibold">
                            <span class="material-symbols-outlined" style="font-size:16px;font-variation-settings:'FILL' 1;">check_circle</span>
                            Access Token configurado
                        </div>
                        <button @onclick="RemoveMercadoPagoTokenAsync" disabled="@_isSavingMp"
                            class="px-3 py-1.5 border border-error text-error rounded-lg text-xs font-semibold hover:bg-error-container transition-colors disabled:opacity-50">
                            Eliminar
                        </button>
                    </div>
                }
                else
                {
                    <div class="space-y-3">
                        <input @bind="_mercadoPagoToken" type="password" placeholder="APP_USR-..."
                            class="w-full px-3 py-2 rounded-lg border border-outline-variant bg-surface text-sm text-on-surface focus:outline-none focus:ring-2 focus:ring-secondary/40" />
                        <p class="text-xs text-on-surface-variant">Tu Access Token de producción de MercadoPago.</p>
                        @if (_mpError is not null)
                        {
                            <p class="text-xs text-error">@_mpError</p>
                        }
                        <div class="flex justify-end">
                            <button @onclick="SaveMercadoPagoTokenAsync" disabled="@_isSavingMp"
                                class="px-5 py-2 bg-secondary text-on-secondary rounded-lg text-sm font-semibold hover:opacity-90 transition-all disabled:opacity-50">
                                @(_isSavingMp ? "Guardando..." : "Guardar")
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-xs text-on-surface-variant">Disponible en el plan Team y superior.</p>
            }
        </div>
    </div>
</section>

@code {
    [Parameter, EditorRequired] public SubscriptionDto Subscription { get; set; } = default!;
    [Parameter, EditorRequired] public EventCallback OnSubscriptionChanged { get; set; }

    private string? _mercadoPagoToken;
    private bool _isSavingMp;
    private string? _mpError;

    private async Task SaveMercadoPagoTokenAsync()
    {
        _mpError = null; _isSavingMp = true;
        try
        {
            await Mediator.Send(new UpdateMercadoPagoTokenCommand(_mercadoPagoToken));
            _mercadoPagoToken = null;
            await OnSubscriptionChanged.InvokeAsync();
        }
        catch (Exception ex) { _mpError = ex.Message; }
        finally { _isSavingMp = false; }
    }

    private async Task RemoveMercadoPagoTokenAsync()
    {
        _mpError = null; _isSavingMp = true;
        try
        {
            await Mediator.Send(new UpdateMercadoPagoTokenCommand(null));
            await OnSubscriptionChanged.InvokeAsync();
        }
        catch (Exception ex) { _mpError = ex.Message; }
        finally { _isSavingMp = false; }
    }
}
