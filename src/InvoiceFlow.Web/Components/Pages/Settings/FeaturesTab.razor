@using InvoiceFlow.Application.Subscriptions.Dtos

<section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-on-surface mb-5">Funcionalidades del plan</h2>
    <div class="space-y-0 divide-y divide-outline-variant">
        @foreach (var feature in GetFeatures())
        {
            <div class="flex items-center justify-between py-3.5">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined @(feature.Enabled ? "text-secondary" : "text-outline-variant")" style="font-size:20px;">@feature.Icon</span>
                    <span class="text-sm font-medium text-on-surface">@feature.Label</span>
                </div>
                @if (feature.Enabled)
                {
                    <span class="flex items-center gap-1.5 text-xs font-semibold text-secondary bg-secondary-container/20 px-2.5 py-1 rounded-full">
                        <span class="material-symbols-outlined" style="font-size:14px;font-variation-settings:'FILL' 1;">check_circle</span>
                        Habilitado
                    </span>
                }
                else
                {
                    <a href="/pricing" class="text-xs font-semibold text-on-surface-variant hover:text-secondary transition-colors">Solo en Pro →</a>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired] public SubscriptionDto Subscription { get; set; } = default!;

    private IEnumerable<FeatureItem> GetFeatures()
    {
        yield return new("Envío por WhatsApp", "chat", Subscription.WhatsAppEnabled);
        yield return new("Reportes avanzados", "bar_chart", Subscription.ReportsEnabled);
        yield return new("Logo personalizado en PDF", "image", Subscription.CustomLogoEnabled);
        yield return new("MercadoPago", "account_balance_wallet", Subscription.MercadoPagoEnabled);
        yield return new($"Hasta {Subscription.MaxUsers} usuario{(Subscription.MaxUsers != 1 ? "s" : "")}", "group", true);
    }

    private sealed record FeatureItem(string Label, string Icon, bool Enabled);
}
