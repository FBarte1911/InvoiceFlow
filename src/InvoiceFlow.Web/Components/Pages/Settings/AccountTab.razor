@using Microsoft.AspNetCore.Components.Authorization

<section class="bg-surface-container-lowest border border-outline-variant rounded-xl p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-on-surface mb-5">Información de cuenta</h2>
    <AuthorizeView>
        <Authorized>
            <div class="space-y-4">
                <div class="flex items-center justify-between py-3 border-b border-outline-variant">
                    <div>
                        <p class="text-xs text-on-surface-variant font-semibold uppercase tracking-wider mb-0.5">Nombre</p>
                        <p class="text-sm font-medium text-on-surface">@(context.User.Identity?.Name ?? "—")</p>
                    </div>
                </div>
                <div class="flex items-center justify-between py-3 border-b border-outline-variant">
                    <div>
                        <p class="text-xs text-on-surface-variant font-semibold uppercase tracking-wider mb-0.5">Email</p>
                        <p class="text-sm font-medium text-on-surface">@(context.User.FindFirst("email")?.Value ?? context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "—")</p>
                    </div>
                </div>
                <div class="flex items-center justify-between py-3">
                    <div>
                        <p class="text-xs text-on-surface-variant font-semibold uppercase tracking-wider mb-0.5">Contraseña</p>
                        <p class="text-sm text-on-surface-variant">Gestionada por Auth0</p>
                    </div>
                    <a href="https://auth0.com" target="_blank" class="px-4 py-2 border border-outline-variant rounded-lg text-xs font-semibold text-on-surface-variant hover:bg-surface-container-high transition-colors">
                        Gestionar
                    </a>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="flex items-center justify-between py-3">
                <div>
                    <p class="text-xs text-on-surface-variant font-semibold uppercase tracking-wider mb-0.5">Modo</p>
                    <p class="text-sm font-medium text-on-surface">Desarrollo local</p>
                </div>
            </div>
        </NotAuthorized>
    </AuthorizeView>
</section>
