@inherits LayoutComponentBase

<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary-fixed-dim": "#bec6e0",
                        "on-primary-container": "#7c839b",
                        "primary-container": "#131b2e",
                        "on-secondary": "#ffffff",
                        "secondary-container": "#3fe1fd",
                        "outline-variant": "#c6c6cd",
                        "surface-bright": "#f8f9ff",
                        "background": "#f8f9ff",
                        "error": "#ba1a1a",
                        "outline": "#76777d",
                        "secondary-fixed": "#a2eeff",
                        "inverse-on-surface": "#eaf1ff",
                        "on-surface-variant": "#45464d",
                        "surface-container-low": "#eff4ff",
                        "on-surface": "#0b1c30",
                        "primary-fixed": "#dae2fd",
                        "primary": "#000000",
                        "secondary": "#006877",
                        "surface-variant": "#d3e4fe",
                        "on-error": "#ffffff",
                        "on-primary": "#ffffff",
                        "surface-container-high": "#dce9ff",
                        "error-container": "#ffdad6",
                        "surface-container": "#e5eeff",
                        "on-background": "#0b1c30",
                        "surface": "#f8f9ff",
                        "on-secondary-fixed": "#001f25",
                        "surface-container-lowest": "#ffffff",
                    },
                    borderRadius: {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    spacing: {
                        "gutter": "16px",
                        "sidebar_width": "256px",
                        "stack_md": "16px",
                        "container_padding": "24px",
                        "stack_sm": "8px",
                        "stack_lg": "32px"
                    },
                    fontFamily: {
                        "mono-sm": ["JetBrains Mono"],
                        "mono-lg": ["JetBrains Mono"],
                        "h2": ["Inter"],
                        "h3": ["Inter"],
                        "body-lg": ["Inter"],
                        "h1": ["Inter"],
                        "body-md": ["Inter"],
                        "mono-md": ["JetBrains Mono"],
                        "body-sm": ["Inter"]
                    },
                    fontSize: {
                        "mono-sm": ["12px", { "lineHeight": "1.4", "fontWeight": "400" }],
                        "mono-lg": ["20px", { "lineHeight": "1.4", "fontWeight": "500" }],
                        "h2": ["30px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "h3": ["24px", { "lineHeight": "1.3", "fontWeight": "600" }],
                        "body-lg": ["18px", { "lineHeight": "1.6", "fontWeight": "400" }],
                        "h1": ["40px", { "lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "body-md": ["16px", { "lineHeight": "1.5", "fontWeight": "400" }],
                        "mono-md": ["14px", { "lineHeight": "1.4", "fontWeight": "500" }],
                        "body-sm": ["14px", { "lineHeight": "1.5", "fontWeight": "400" }]
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .login-bg-pattern {
            background-color: #0F172A;
            background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0);
            background-size: 40px 40px;
        }
    </style>
    <HeadOutlet />
</head>
<body class="bg-background text-on-surface font-body-md min-h-screen flex overflow-hidden">
    @Body
    <script src="_framework/blazor.web.js"></script>
</body>
</html>
