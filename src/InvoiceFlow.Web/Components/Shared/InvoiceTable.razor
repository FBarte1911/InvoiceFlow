@using InvoiceFlow.Application.Invoicing.Dtos
@using InvoiceFlow.Domain.Invoicing

<div class="bg-surface rounded-xl border border-outline-variant shadow-sm overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-surface-container-low border-b border-outline-variant">
                <th class="px-5 py-3.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">N° Factura</th>
                <th class="px-5 py-3.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Cliente</th>
                <th class="px-5 py-3.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Monto</th>
                <th class="px-5 py-3.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Estado</th>
                <th class="px-5 py-3.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Emisión</th>
                <th class="px-5 py-3.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Vencimiento</th>
                <th class="px-5 py-3.5 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-right">Acciones</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-outline-variant">
            @foreach (var invoice in Invoices)
            {
                <tr class="hover:bg-surface-container-low transition-colors group">
                    <td class="px-5 py-3.5" style="font-family: 'JetBrains Mono', monospace; font-size: 13px; color: #45464d;">
                        <a href="/invoices/@invoice.Id" class="hover:text-secondary transition-colors">@invoice.Number</a>
                    </td>
                    <td class="px-5 py-3.5">
                        <div class="font-medium text-sm text-on-surface">@invoice.ClientName</div>
                        <div class="text-xs text-on-surface-variant">@invoice.ClientEmail</div>
                    </td>
                    <td class="px-5 py-3.5 font-semibold text-sm text-on-surface" style="font-family: 'JetBrains Mono', monospace;">
                        @invoice.Currency @invoice.Total.ToString("N2")
                    </td>
                    <td class="px-5 py-3.5">
                        <span class="@GetBadgeClass(invoice.Status)">@StatusLabel(invoice.Status)</span>
                    </td>
                    <td class="px-5 py-3.5 text-sm text-on-surface-variant">@invoice.IssueDate.ToString("dd MMM yyyy")</td>
                    <td class="px-5 py-3.5 text-sm @(invoice.DueDate < DateOnly.FromDateTime(DateTime.Today) && invoice.Status == InvoiceStatus.Sent ? "text-error font-medium" : "text-on-surface-variant")">
                        @invoice.DueDate.ToString("dd MMM yyyy")
                    </td>
                    <td class="px-5 py-3.5 text-right">
                        <a href="/invoices/@invoice.Id" class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium border border-outline-variant rounded-lg text-on-surface-variant hover:bg-surface-container-high transition-colors">
                            <span class="material-symbols-outlined" style="font-size:14px;">visibility</span>
                            Ver
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<InvoiceDto> Invoices { get; set; } = [];

    private static string StatusLabel(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft     => "Borrador",
        InvoiceStatus.Sent      => "Enviada",
        InvoiceStatus.Paid      => "Cobrada",
        InvoiceStatus.Overdue   => "Vencida",
        InvoiceStatus.Cancelled => "Cancelada",
        _                       => status.ToString()
    };

    private static string GetBadgeClass(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Paid      => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800 border border-green-200",
        InvoiceStatus.Sent      => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-cyan-100 text-cyan-800 border border-cyan-200",
        InvoiceStatus.Overdue   => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 border border-amber-200",
        InvoiceStatus.Draft     => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600 border border-gray-200",
        InvoiceStatus.Cancelled => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500 border border-gray-200",
        _                       => "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-600"
    };
}
